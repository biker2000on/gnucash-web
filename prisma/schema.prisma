  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())

  @@map("gnucash_web_book_settings")
}

// Budget auto-funding rules: when a matching deposit lands, allocate
// amounts across envelope accounts.
model gnucash_web_budget_funding_rules {
  id                        Int      @id @default(autoincrement())
  book_guid                 String   @db.VarChar(32)
  name                      String   @db.VarChar(255)
  trigger_account_guid      String?  @db.VarChar(32)
  trigger_description_match String?  @db.VarChar(255)
  min_amount                Decimal? @db.Decimal(12, 2)
  /// [{accountGuid, amount}]
  allocations               Json     @db.JsonB
  active                    Boolean  @default(true)
  last_applied_txn_guid     String?  @db.VarChar(32)
  created_at                DateTime @default(now())
  updated_at                DateTime @default(now())

  @@index([book_guid], map: "idx_budget_funding_rules_book")
  @@map("gnucash_web_budget_funding_rules")
}

// Renewals & contracts: upcoming renewal dates with reminder lead time.
model gnucash_web_renewals {
  id              Int       @id @default(autoincrement())
  book_guid       String    @db.VarChar(32)
  name            String    @db.VarChar(255)
  renewal_date    DateTime  @db.Date
  amount          Decimal?  @db.Decimal(12, 2)
  cadence_months  Int       @default(12)
  remind_days     Int       @default(30)
  /// manual | subscription | insurance
  source          String    @default("manual") @db.VarChar(20)
  notes           String?   @db.Text
  dismissed_until DateTime? @db.Date
  created_at      DateTime  @default(now())
  updated_at      DateTime  @default(now())

  @@index([book_guid, renewal_date], map: "idx_renewals_book_date")
  @@map("gnucash_web_renewals")
}

// Home module: rooms, inventory items, maintenance tasks, and the service log.
model gnucash_web_home_rooms {
  id         Int      @id @default(autoincrement())
  book_guid  String   @db.VarChar(32)
  name       String   @db.VarChar(255)
  sort_order Int      @default(0)
  created_at DateTime @default(now())

  items gnucash_web_home_items[]

  @@index([book_guid], map: "idx_home_rooms_book")
  @@map("gnucash_web_home_rooms")
}

model gnucash_web_home_items {
  id               Int       @id @default(autoincrement())
  book_guid        String    @db.VarChar(32)
  room_id          Int
  name             String    @db.VarChar(255)
  category         String?   @db.VarChar(50)
  est_value        Decimal?  @db.Decimal(12, 2)
  purchase_date    DateTime? @db.Date
  receipt_id       Int?
  photo_key        String?   @db.VarChar(500)
  warranty_expires DateTime? @db.Date
  serial           String?   @db.VarChar(100)
  notes            String?   @db.Text
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now())

  room        gnucash_web_home_rooms       @relation(fields: [room_id], references: [id], onDelete: Cascade)
  tasks       gnucash_web_home_tasks[]
  service_log gnucash_web_home_service_log[]

  @@index([room_id], map: "idx_home_items_room")
  @@index([book_guid], map: "idx_home_items_book")
  @@map("gnucash_web_home_items")
}

model gnucash_web_home_tasks {
  id             Int       @id @default(autoincrement())
  book_guid      String    @db.VarChar(32)
  name           String    @db.VarChar(255)
  cadence_months Int?
  /// spring | summer | fall | winter
  season         String?   @db.VarChar(20)
  item_id        Int?
  last_done      DateTime? @db.Date
  active         Boolean   @default(true)
  notes          String?   @db.Text
  created_at     DateTime  @default(now())
  updated_at     DateTime  @default(now())

  item        gnucash_web_home_items?        @relation(fields: [item_id], references: [id], onDelete: SetNull)
  service_log gnucash_web_home_service_log[]

  @@index([book_guid], map: "idx_home_tasks_book")
  @@map("gnucash_web_home_tasks")
}

model gnucash_web_home_service_log {
  id           Int       @id @default(autoincrement())
  book_guid    String    @db.VarChar(32)
  task_id      Int?
  item_id      Int?
  service_date DateTime  @db.Date
  cost         Decimal?  @db.Decimal(12, 2)
  vendor       String?   @db.VarChar(255)
  txn_guid     String?   @db.VarChar(32)
  notes        String?   @db.Text
  created_at   DateTime  @default(now())

  task gnucash_web_home_tasks? @relation(fields: [task_id], references: [id], onDelete: SetNull)
  item gnucash_web_home_items? @relation(fields: [item_id], references: [id], onDelete: SetNull)

  @@index([book_guid], map: "idx_home_service_log_book")
  @@map("gnucash_web_home_service_log")
}
