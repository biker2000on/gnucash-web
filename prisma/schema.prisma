  account_tags     gnucash_web_account_tags[]

  @@unique([book_guid, name], map: "idx_tags_book_name")
  @@index([book_guid], map: "idx_tags_book")
}

model gnucash_web_transaction_tags {
  transaction_guid String @db.VarChar(32)
