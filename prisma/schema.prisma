// GnuCash Web - Prisma Schema
// Introspected from GnuCash PostgreSQL database with added relations

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Core GnuCash Tables (DO NOT MODIFY STRUCTURE)
// ============================================

model accounts {
  guid           String  @id @db.VarChar(32)
  name           String  @db.VarChar(2048)
  account_type   String  @db.VarChar(2048)
  commodity_guid String? @db.VarChar(32)
  commodity_scu  Int
  non_std_scu    Int
  parent_guid    String? @db.VarChar(32)
  code           String? @db.VarChar(2048)
  description    String? @db.VarChar(2048)
  hidden         Int?
  placeholder    Int?

  // Relations
  commodity      commodities?    @relation(fields: [commodity_guid], references: [guid])
  parent         accounts?       @relation("AccountHierarchy", fields: [parent_guid], references: [guid])
  children       accounts[]      @relation("AccountHierarchy")
  splits         splits[]
  budget_amounts budget_amounts[]
  lots           lots[]
  tags           gnucash_web_account_tags[]
}

model transactions {
  guid          String    @id @db.VarChar(32)
  currency_guid String    @db.VarChar(32)
  num           String    @db.VarChar(2048)
  post_date     DateTime? @db.Timestamp(6)
  enter_date    DateTime? @db.Timestamp(6)
  description   String?   @db.VarChar(2048)

  // Relations
  currency commodities @relation(fields: [currency_guid], references: [guid])
  splits   splits[]
  tags     gnucash_web_transaction_tags[]

  @@index([post_date], map: "tx_post_date_index")
}

model splits {
  guid            String    @id @db.VarChar(32)
  tx_guid         String    @db.VarChar(32)
  account_guid    String    @db.VarChar(32)
  memo            String    @db.VarChar(2048)
  action          String    @db.VarChar(2048)
  reconcile_state String    @db.VarChar(1)
  reconcile_date  DateTime? @db.Timestamp(6)
  value_num       BigInt
  value_denom     BigInt
  quantity_num    BigInt
  quantity_denom  BigInt
  lot_guid        String?   @db.VarChar(32)

  // Relations
  transaction transactions @relation(fields: [tx_guid], references: [guid], onDelete: Cascade)
  account     accounts     @relation(fields: [account_guid], references: [guid])
  lot         lots?        @relation(fields: [lot_guid], references: [guid])

  @@index([account_guid], map: "splits_account_guid_index")
  @@index([tx_guid], map: "splits_tx_guid_index")
}

model commodities {
  guid         String  @id @db.VarChar(32)
  namespace    String  @db.VarChar(2048)
  mnemonic     String  @db.VarChar(2048)
  fullname     String? @db.VarChar(2048)
  cusip        String? @db.VarChar(2048)
  fraction     Int
  quote_flag   Int
  quote_source String? @db.VarChar(2048)
  quote_tz     String? @db.VarChar(2048)

  // Relations
  accounts              accounts[]
  transactions          transactions[]
  prices_as_commodity   prices[]       @relation("PriceCommodity")
  prices_as_currency    prices[]       @relation("PriceCurrency")
}

model prices {
  guid           String   @id @db.VarChar(32)
  commodity_guid String   @db.VarChar(32)
  currency_guid  String   @db.VarChar(32)
  date           DateTime @db.Timestamp(6)
  source         String?  @db.VarChar(2048)
  type           String?  @db.VarChar(2048)
  value_num      BigInt
  value_denom    BigInt

  // Relations
  commodity commodities @relation("PriceCommodity", fields: [commodity_guid], references: [guid])
  currency  commodities @relation("PriceCurrency", fields: [currency_guid], references: [guid])
}

model budgets {
  guid        String  @id @db.VarChar(32)
  name        String  @db.VarChar(2048)
  description String? @db.VarChar(2048)
  num_periods Int

  // Relations
  amounts     budget_amounts[]
  recurrences recurrences[]
}

model budget_amounts {
  id           Int    @id @default(autoincrement())
  budget_guid  String @db.VarChar(32)
  account_guid String @db.VarChar(32)
  period_num   Int
  amount_num   BigInt
  amount_denom BigInt

  // Relations
  budget  budgets  @relation(fields: [budget_guid], references: [guid], onDelete: Cascade)
  account accounts @relation(fields: [account_guid], references: [guid])

  @@unique([budget_guid, account_guid, period_num])
}

model recurrences {
  id                        Int      @id @default(autoincrement())
  obj_guid                  String   @db.VarChar(32)
  recurrence_mult           Int
  recurrence_period_type    String   @db.VarChar(2048)
  recurrence_period_start   DateTime @db.Date
  recurrence_weekend_adjust String   @db.VarChar(2048)

  // Relations (can be linked to budgets or scheduled transactions)
  budget budgets? @relation(fields: [obj_guid], references: [guid])
}

model lots {
  guid         String  @id @db.VarChar(32)
  account_guid String? @db.VarChar(32)
  is_closed    Int

  // Relations
  account accounts? @relation(fields: [account_guid], references: [guid])
  splits  splits[]
}

// ============================================
// Other GnuCash Tables (Less frequently used)
// ============================================

model books {
  guid               String  @id @db.VarChar(32)
  root_account_guid  String  @db.VarChar(32)
  root_template_guid String  @db.VarChar(32)
  name               String? @db.VarChar(255)
  description        String? @db.Text
}

model billterms {
  guid           String  @id @db.VarChar(32)
  name           String  @db.VarChar(2048)
  description    String  @db.VarChar(2048)
  refcount       Int
  invisible      Int
  parent         String? @db.VarChar(32)
  type           String  @db.VarChar(2048)
  duedays        Int?
  discountdays   Int?
  discount_num   BigInt?
  discount_denom BigInt?
  cutoff         Int?
}

model customers {
  guid           String  @id @db.VarChar(32)
  name           String  @db.VarChar(2048)
  id             String  @db.VarChar(2048)
  notes          String  @db.VarChar(2048)
  active         Int
  discount_num   BigInt
  discount_denom BigInt
  credit_num     BigInt
  credit_denom   BigInt
  currency       String  @db.VarChar(32)
