// Tagging: flat labels for accounts and transactions.
// NOTE: junction tables intentionally have NO DB foreign keys to the GnuCash
// transactions/accounts tables (GnuCash schema is untouched); the Prisma
// relations below are app-level joins only.
model gnucash_web_tags {
  id          Int       @id @default(autoincrement())
  /// Tags are book-scoped; name is unique per book, not globally
  book_guid   String?   @db.VarChar(32)
  name        String    @db.VarChar(100)
  color       String?   @db.VarChar(20)
  description String?   @db.Text
  created_at  DateTime? @default(now())

