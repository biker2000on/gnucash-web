  addr_name      String? @db.VarChar(1024)
  addr_addr1     String? @db.VarChar(1024)
  addr_addr2     String? @db.VarChar(1024)
  addr_addr3     String? @db.VarChar(1024)
  addr_addr4     String? @db.VarChar(1024)
  addr_phone     String? @db.VarChar(128)
  addr_fax       String? @db.VarChar(128)
  addr_email     String? @db.VarChar(256)
  shipaddr_name  String? @db.VarChar(1024)
  shipaddr_addr1 String? @db.VarChar(1024)
  shipaddr_addr2 String? @db.VarChar(1024)
  shipaddr_addr3 String? @db.VarChar(1024)
  shipaddr_addr4 String? @db.VarChar(1024)
  shipaddr_phone String? @db.VarChar(128)
  shipaddr_fax   String? @db.VarChar(128)
  shipaddr_email String? @db.VarChar(256)
  terms          String? @db.VarChar(32)
  tax_included   Int?
  taxtable       String? @db.VarChar(32)
}

model employees {
  guid          String  @id @db.VarChar(32)
  username      String  @db.VarChar(2048)
  id            String  @db.VarChar(2048)
  language      String  @db.VarChar(2048)
  acl           String  @db.VarChar(2048)
  active        Int
  currency      String  @db.VarChar(32)
  ccard_guid    String? @db.VarChar(32)
  workday_num   BigInt
  workday_denom BigInt
  rate_num      BigInt
  rate_denom    BigInt
  addr_name     String? @db.VarChar(1024)
  addr_addr1    String? @db.VarChar(1024)
  addr_addr2    String? @db.VarChar(1024)
  addr_addr3    String? @db.VarChar(1024)
  addr_addr4    String? @db.VarChar(1024)
  addr_phone    String? @db.VarChar(128)
  addr_fax      String? @db.VarChar(128)
  addr_email    String? @db.VarChar(256)
}

model entries {
  guid             String    @id @db.VarChar(32)
  date             DateTime  @db.Timestamp(6)
  date_entered     DateTime? @db.Timestamp(6)
  description      String?   @db.VarChar(2048)
  action           String?   @db.VarChar(2048)
  notes            String?   @db.VarChar(2048)
  quantity_num     BigInt?
  quantity_denom   BigInt?
  i_acct           String?   @db.VarChar(32)
  i_price_num      BigInt?
  i_price_denom    BigInt?
  i_discount_num   BigInt?
  i_discount_denom BigInt?
  invoice          String?   @db.VarChar(32)
  i_disc_type      String?   @db.VarChar(2048)
  i_disc_how       String?   @db.VarChar(2048)
  i_taxable        Int?
  i_taxincluded    Int?
  i_taxtable       String?   @db.VarChar(32)
  b_acct           String?   @db.VarChar(32)
  b_price_num      BigInt?
  b_price_denom    BigInt?
  bill             String?   @db.VarChar(32)
  b_taxable        Int?
  b_taxincluded    Int?
  b_taxtable       String?   @db.VarChar(32)
  b_paytype        Int?
  billable         Int?
  billto_type      Int?
  billto_guid      String?   @db.VarChar(32)
  order_guid       String?   @db.VarChar(32)
}

model invoices {
  guid             String    @id @db.VarChar(32)
  id               String    @db.VarChar(2048)
  date_opened      DateTime? @db.Timestamp(6)
  date_posted      DateTime? @db.Timestamp(6)
  notes            String    @db.VarChar(2048)
  active           Int
  currency         String    @db.VarChar(32)
  owner_type       Int?
  owner_guid       String?   @db.VarChar(32)
  terms            String?   @db.VarChar(32)
  billing_id       String?   @db.VarChar(2048)
  post_txn         String?   @db.VarChar(32)
  post_lot         String?   @db.VarChar(32)
  post_acc         String?   @db.VarChar(32)
  billto_type      Int?
  billto_guid      String?   @db.VarChar(32)
  charge_amt_num   BigInt?
  charge_amt_denom BigInt?
}

model jobs {
  guid       String  @id @db.VarChar(32)
  id         String  @db.VarChar(2048)
  name       String  @db.VarChar(2048)
  reference  String  @db.VarChar(2048)
  active     Int
  owner_type Int?
  owner_guid String? @db.VarChar(32)
}

model orders {
  guid        String   @id @db.VarChar(32)
  id          String   @db.VarChar(2048)
  notes       String   @db.VarChar(2048)
  reference   String   @db.VarChar(2048)
  active      Int
  date_opened DateTime @db.Timestamp(6)
  date_closed DateTime @db.Timestamp(6)
  owner_type  Int
  owner_guid  String   @db.VarChar(32)
}

model schedxactions {
  guid              String    @id @db.VarChar(32)
  name              String?   @db.VarChar(2048)
  enabled           Int
  start_date        DateTime? @db.Date
  end_date          DateTime? @db.Date
  last_occur        DateTime? @db.Date
  num_occur         Int
  rem_occur         Int
  auto_create       Int
  auto_notify       Int
  adv_creation      Int
  adv_notify        Int
  instance_count    Int
  template_act_guid String    @db.VarChar(32)
}

model slots {
  id                Int       @id @default(autoincrement())
  obj_guid          String    @db.VarChar(32)
  name              String    @db.VarChar(4096)
  slot_type         Int
  int64_val         BigInt?
  string_val        String?   @db.VarChar(4096)
  double_val        Float?
  timespec_val      DateTime? @db.Timestamp(6)
  guid_val          String?   @db.VarChar(32)
  numeric_val_num   BigInt?
  numeric_val_denom BigInt?
  gdate_val         DateTime? @db.Date

  @@index([obj_guid], map: "slots_guid_index")
}

model taxtable_entries {
  id           Int    @id @default(autoincrement())
  taxtable     String @db.VarChar(32)
  account      String @db.VarChar(32)
  amount_num   BigInt
  amount_denom BigInt
  type         Int
}

model taxtables {
  guid      String  @id @db.VarChar(32)
  name      String  @db.VarChar(50)
  refcount  BigInt
  invisible Int
  parent    String? @db.VarChar(32)
}

model vendors {
  guid         String  @id @db.VarChar(32)
  name         String  @db.VarChar(2048)
  id           String  @db.VarChar(2048)
  notes        String  @db.VarChar(2048)
  currency     String  @db.VarChar(32)
  active       Int
  tax_override Int
  addr_name    String? @db.VarChar(1024)
  addr_addr1   String? @db.VarChar(1024)
  addr_addr2   String? @db.VarChar(1024)
  addr_addr3   String? @db.VarChar(1024)
  addr_addr4   String? @db.VarChar(1024)
  addr_phone   String? @db.VarChar(128)
  addr_fax     String? @db.VarChar(128)
  addr_email   String? @db.VarChar(256)
  terms        String? @db.VarChar(32)
  tax_inc      String? @db.VarChar(2048)
  tax_table    String? @db.VarChar(32)
}

model versions {
  table_name    String @id @db.VarChar(50)
  table_version Int
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model gnclock {
  hostname String? @db.VarChar(255)
  pid      Int?

  @@ignore
}

// ============================================
// Extension Tables (GnuCash Web specific)
// These are separate from GnuCash schema
// ============================================

model gnucash_web_users {
  id               Int       @id @default(autoincrement())
  username         String    @unique @db.VarChar(255)
  password_hash    String?   @db.VarChar(255)
  balance_reversal String    @default("none") @db.VarChar(20)
  created_at       DateTime  @default(now())
  last_login       DateTime?
  email            String?   @unique @db.VarChar(255)
  oidc_subject     String?   @db.VarChar(255)
  oidc_issuer      String?   @db.VarChar(500)
  auth_method      String    @default("password") @db.VarChar(20)
  display_name     String?   @db.VarChar(255)
  avatar_url       String?

  @@unique([oidc_issuer, oidc_subject])

  // Relations
  audit_logs             gnucash_web_audit[]
  saved_reports          gnucash_web_saved_reports[]
  preferences            gnucash_web_user_preferences[]
  tool_configs           gnucash_web_tool_config[]
  ai_config              gnucash_web_ai_config?
  permissions            gnucash_web_book_permissions[]  @relation("permissions_user")
  granted_permissions    gnucash_web_book_permissions[]  @relation("permissions_granter")
  simplefin_connections  gnucash_web_simplefin_connections[]
  created_invitations    gnucash_web_invitations[]       @relation("invitation_creator")
  used_invitations       gnucash_web_invitations[]       @relation("invitation_user")
  revoked_invitations    gnucash_web_invitations[]       @relation("invitation_revoker")
}

model gnucash_web_audit {
  id          Int       @id @default(autoincrement())
  user_id     Int?
  /// Book the mutation happened in; NULL only for unattributable legacy rows
  book_guid   String?   @db.VarChar(32)
  action      String    @db.VarChar(50) // CREATE, UPDATE, DELETE
  entity_type String    @db.VarChar(50) // transaction, account, etc.
  entity_guid String    @db.VarChar(32)
  old_values  Json?
  new_values  Json?
  created_at  DateTime  @default(now())

  // Relations
  user        gnucash_web_users? @relation(fields: [user_id], references: [id])

  @@index([book_guid, created_at(sort: Desc)], map: "idx_audit_book_created")
}

model gnucash_web_saved_reports {
  id               Int       @id @default(autoincrement())
  user_id          Int?
  base_report_type String    @db.VarChar(50)
  name             String    @db.VarChar(255)
  description      String?   @db.Text
  config           Json      @default("{}")
  filters          Json?
  is_starred       Boolean   @default(false)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  // Relations
  user             gnucash_web_users? @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model gnucash_web_commodity_metadata {
  id               Int       @id @default(autoincrement())
  commodity_guid   String    @db.VarChar(32)
  mnemonic         String    @db.VarChar(50)
  sector           String?   @db.VarChar(255)
  industry         String?   @db.VarChar(255)
  sector_weights   Json?     // For ETFs/funds: { "Technology": 25.5, "Healthcare": 15.2, ... }
  asset_class      String?   @db.VarChar(50)  // "stock", "etf", "mutual_fund", "bond"
  last_updated     DateTime  @default(now())
  created_at       DateTime  @default(now())

  @@unique([commodity_guid])
  @@index([mnemonic])
}

model gnucash_web_depreciation_schedules {
  id                    Int       @id @default(autoincrement())
  account_guid          String    @db.VarChar(32)
  purchase_price        Decimal   @db.Decimal(15, 2)
  purchase_date         DateTime  @db.Date
  useful_life_years     Int
  salvage_value         Decimal   @db.Decimal(15, 2) @default(0)
  method                String    @db.VarChar(30)  // "straight-line", "declining-balance"
  decline_rate          Decimal?  @db.Decimal(5, 4)  // For declining balance, e.g., 0.2000
  contra_account_guid   String    @db.VarChar(32)
  frequency             String    @db.VarChar(20) @default("monthly")  // "monthly", "quarterly", "yearly"
  is_appreciation       Boolean   @default(false)
  last_transaction_date DateTime? @db.Date
  enabled               Boolean   @default(true)
  notes                 String?   @db.Text
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now())

  @@unique([account_guid])
  @@index([account_guid])
}

model gnucash_web_user_preferences {
  id               Int       @id @default(autoincrement())
  user_id          Int
  preference_key   String    @db.VarChar(100)
  preference_value String    @db.Text
  updated_at       DateTime  @default(now())

  // Relations
  user             gnucash_web_users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, preference_key])
  @@index([user_id])
}

model gnucash_web_tool_config {
  id           Int       @id @default(autoincrement())
  user_id      Int?
  book_guid    String    @db.VarChar(32)
  tool_type    String    @db.VarChar(50)
  name         String    @db.VarChar(255)
  account_guid String?   @db.VarChar(32)
  config       Json      @default("{}")
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  user         gnucash_web_users? @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, book_guid, tool_type])
}

model gnucash_web_account_preferences {
  account_guid            String   @id @db.VarChar(32)
  cost_basis_method       String?  @db.VarChar(20) // 'fifo', 'lifo', 'average'
  lot_assignment_method   String?  @db.VarChar(20) // 'fifo', 'lifo', 'average'
  is_retirement           Boolean  @default(false)
  retirement_account_type String?  @db.VarChar(20)
  tax_related             Boolean  @default(false)
  owner                   String?  @db.VarChar(10) // 'self', 'spouse', 'joint'

  @@map("gnucash_web_account_preferences")
}

model gnucash_web_contribution_limits {
  id             Int      @id @default(autoincrement())
  tax_year       Int
  account_type   String   @db.VarChar(20)
  base_limit     Decimal  @db.Decimal(12, 2)
  catch_up_limit Decimal  @default(0) @db.Decimal(12, 2)
  catch_up_age   Int      @default(50)
  notes          String?  @db.VarChar(255)

  @@unique([tax_year, account_type])
  @@map("gnucash_web_contribution_limits")
}

model gnucash_web_contribution_tax_year {
  split_guid String @id @db.VarChar(32)
  tax_year   Int

  @@map("gnucash_web_contribution_tax_year")
}

model gnucash_web_tax_mappings {
  account_guid String   @id @db.VarChar(32)
  tax_category String   @db.VarChar(40)
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now())

  @@index([tax_category])
  @@map("gnucash_web_tax_mappings")
}

model gnucash_web_transaction_types {
  split_guid        String @id @db.VarChar(32)  // keyed by the account's split in the transaction
  transaction_type  String @db.VarChar(30)       // 'buy', 'sell', 'dividend', 'stock_split', 'return_of_capital', 'reinvested_dividend', 'other'

  @@map("gnucash_web_transaction_types")
}

model gnucash_web_receipts {
  id               Int       @id @default(autoincrement())
  book_guid        String    @db.VarChar(32)
  transaction_guid String?   @db.VarChar(32)
  filename         String    @db.VarChar(255)
  storage_key      String    @db.VarChar(500)
  thumbnail_key    String?   @db.VarChar(500)
  mime_type        String    @db.VarChar(100)
  file_size        Int
  ocr_text         String?   @db.Text
  ocr_status       String    @default("pending") @db.VarChar(20)
  extracted_data   Json?     @db.JsonB
  hsa_eligible     Boolean   @default(false)
  hsa_reimbursed_txn_guid String? @db.VarChar(32)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now())
  created_by       Int?

  @@index([transaction_guid])
  @@index([book_guid])
  @@index([created_by])
  @@map("gnucash_web_receipts")
}

model gnucash_web_payslips {
  id               Int       @id @default(autoincrement())
  book_guid        String    @db.VarChar(32)
  pay_date         DateTime  @db.Date
  pay_period_start DateTime? @db.Date
  pay_period_end   DateTime? @db.Date
  employer_name    String    @db.VarChar(255)
  gross_pay        Decimal?  @db.Decimal(12, 2)
  net_pay          Decimal?  @db.Decimal(12, 2)
  currency         String    @default("USD") @db.VarChar(10)
  source           String    @default("pdf_upload") @db.VarChar(20)
  source_id        String?   @db.VarChar(255)
  transaction_guid String?   @db.VarChar(32)
  storage_key      String?   @db.VarChar(500)
  thumbnail_key    String?   @db.VarChar(500)
  line_items       Json?     @db.JsonB
  raw_response     Json?     @db.JsonB
  status           String    @default("processing") @db.VarChar(20)
  error_message    String?   @db.Text
  deposit_account_guid String? @db.VarChar(32)
  created_by       Int?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now())

  @@index([book_guid])
  @@index([pay_date])
  @@index([status])
  @@index([employer_name])
  @@map("gnucash_web_payslips")
}

model gnucash_web_payslip_mappings {
  id                 Int      @id @default(autoincrement())
  book_guid          String   @db.VarChar(32)
  employer_name      String   @db.VarChar(255)
  normalized_label   String   @db.VarChar(255)
  line_item_category String   @db.VarChar(30)
  account_guid       String   @db.VarChar(32)
  created_at         DateTime @default(now())
  updated_at         DateTime @default(now())

  @@unique([book_guid, employer_name, normalized_label, line_item_category])
  @@index([book_guid, employer_name])
  @@map("gnucash_web_payslip_mappings")
}

model gnucash_web_payslip_templates {
  id            Int      @id @default(autoincrement())
  book_guid     String   @db.VarChar(32)
  employer_name String   @db.VarChar(255)
