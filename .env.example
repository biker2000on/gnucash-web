# Database Connection (required)
# For docker-compose: DATABASE_URL=postgresql://gnucash:gnucash@postgres:5432/gnucash
# For external DB:    DATABASE_URL=postgresql://user:password@host:5432/gnucash_db
DATABASE_URL=postgresql://gnucash:gnucash@postgres:5432/gnucash

# PostgreSQL Container (used by docker-compose postgres service)
# POSTGRES_USER=gnucash
# POSTGRES_PASSWORD=gnucash
# POSTGRES_DB=gnucash

# NextAuth.js Configuration (required for authentication)
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Redis Configuration (required for background jobs)
# When using docker-compose, this is set automatically to redis://redis:6379
REDIS_URL=redis://localhost:6379

# AI Configuration (optional — also configurable via Settings > AI in the app)
# OpenAI:
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o
# AI_API_KEY=sk-your-api-key
# Anthropic:
# AI_BASE_URL=https://api.anthropic.com/v1
# AI_MODEL=claude-sonnet-4-20250514
# AI_API_KEY=sk-ant-your-api-key
# Ollama (local):
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=llama3.2
# AI_API_KEY=ollama

# Receipt Storage (optional — defaults to filesystem)
# RECEIPT_STORAGE=filesystem
# For S3-compatible storage (MinIO, AWS S3, etc.):
# RECEIPT_STORAGE=s3
# RECEIPT_S3_ENDPOINT=http://minio:9000
# RECEIPT_S3_BUCKET=gnucash-receipts
# RECEIPT_S3_REGION=us-east-1
# RECEIPT_S3_ACCESS_KEY=minioadmin
# RECEIPT_S3_SECRET_KEY=minioadmin

# MinIO (optional — only if using --profile storage with docker compose)
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin

# Watchtower (production only — for auto-updating containers from ghcr.io)
# WATCHTOWER_REPO_USER=your-github-username
# WATCHTOWER_REPO_PASS=ghp_your-personal-access-token-with-read-packages
