# PostgreSQL Configuration
# DATABASE_URL is constructed automatically from these in docker-compose.prod.yml.
# For standalone (non-compose) use, set DATABASE_URL directly instead.
# DATABASE_URL=postgresql://user:password@host:5432/gnucash_db
POSTGRES_USER=gnucash
POSTGRES_PASSWORD=gnucash
POSTGRES_DB=gnucash

# NextAuth.js Configuration (required for authentication)
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Redis Configuration (required for background jobs)
# When using docker-compose, this is set automatically to redis://redis:6379
REDIS_URL=redis://localhost:6379

# AI Configuration (optional — also configurable via Settings > AI in the app)
# OpenAI:
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o
# AI_API_KEY=sk-your-api-key
# Anthropic:
# AI_BASE_URL=https://api.anthropic.com/v1
# AI_MODEL=claude-sonnet-4-20250514
# AI_API_KEY=sk-ant-your-api-key
# Ollama (local):
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=llama3.2
# AI_API_KEY=ollama

# Host Port Configuration (optional — for docker-compose port mapping)
# APP_PORT=3000
# POSTGRES_PORT=5432
# POSTGRES_DATA_DIR=./postgres-data
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001

# Receipt Storage (defaults to s3 with MinIO in docker-compose.prod.yml)
# In production compose, RECEIPT_S3_* defaults point to the minio service automatically.
# Override these only if using an external S3-compatible provider (AWS S3, etc.).
# RECEIPT_STORAGE=s3
# RECEIPT_S3_ENDPOINT=http://minio:9000
# RECEIPT_S3_BUCKET=gnucash-receipts
# RECEIPT_S3_REGION=us-east-1
# RECEIPT_S3_ACCESS_KEY=minioadmin
# RECEIPT_S3_SECRET_KEY=minioadmin

# MinIO (optional — enable with: --profile storage)
# The root user/password are also used as the default S3 access/secret keys.
# To create access keys separate from root credentials:
#   1. Start MinIO: docker compose -f docker-compose.prod.yml --profile storage up -d minio
#   2. Open the MinIO console at http://<host>:9001 (login with root user/password below)
#   3. Go to Access Keys > Create Access Key — copy the generated key pair
#   4. Set RECEIPT_S3_ACCESS_KEY and RECEIPT_S3_SECRET_KEY to the new key pair
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
