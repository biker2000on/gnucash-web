# PostgreSQL Configuration
# DATABASE_URL is constructed automatically from these in docker-compose.prod.yml.
# For standalone (non-compose) use, set DATABASE_URL directly instead.
# DATABASE_URL=postgresql://user:password@host:5432/gnucash_db
POSTGRES_USER=gnucash
POSTGRES_PASSWORD=gnucash
POSTGRES_DB=gnucash

# NextAuth.js Configuration (required for authentication)
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# OIDC Single Sign-On (optional — e.g. Pocket ID, Authelia, Keycloak)
# When unset, only username/password login is available.
# The provider must allow the callback URL: {NEXTAUTH_URL}/api/auth/oidc/callback
# Flow: authorization code + PKCE (S256); requested scopes: openid profile email.
# OIDC_ISSUER=https://id.example.com
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# Display name shown on the login button ("Sign in with ...")
# OIDC_PROVIDER_NAME=Pocket ID

# Redis Configuration (required for background jobs)
# When using docker-compose, this is set automatically to redis://redis:6379
REDIS_URL=redis://localhost:6379

# SimpleFin import matching (optional)
# Existing manually entered transactions and transfer dedup candidates are matched within this +/- day window.
# SIMPLEFIN_MATCH_WINDOW_DAYS=3

# AI Configuration (optional — also configurable via Settings > AI in the app)
# OpenAI:
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o
# AI_API_KEY=sk-your-api-key
# Anthropic:
# AI_BASE_URL=https://api.anthropic.com/v1
# AI_MODEL=claude-sonnet-4-20250514
# AI_API_KEY=sk-ant-your-api-key
# Ollama (local):
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=llama3.2
# AI_API_KEY=ollama

# Email Delivery (optional — enables emailing notifications/digests to users)
# Email is disabled until SMTP_HOST is set. Users opt in per-account under
# Settings > Email Notifications.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false            # true for implicit TLS (usually port 465)
# SMTP_USER=mailer@example.com
# SMTP_PASS=app-password
# SMTP_FROM="GnuCash Web <gnucash-web@example.com>"
# APP_BASE_URL=https://gnucash.example.com   # used for links in email bodies

# Host Port Configuration (optional — for docker-compose port mapping)
# APP_PORT=3000
# POSTGRES_PORT=5432
# POSTGRES_DATA_DIR=./postgres-data
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001

# Receipt Storage (defaults to s3 with MinIO in docker-compose.prod.yml)
# In production compose, RECEIPT_S3_* defaults point to the minio service automatically.
# Override these only if using an external S3-compatible provider (AWS S3, etc.).
# RECEIPT_STORAGE=s3
# RECEIPT_S3_ENDPOINT=http://minio:9000
# RECEIPT_S3_BUCKET=gnucash-receipts
# RECEIPT_S3_REGION=us-east-1
# RECEIPT_S3_ACCESS_KEY=minioadmin
# RECEIPT_S3_SECRET_KEY=minioadmin

# Email-in Document Ingestion (optional — forward receipts/statements/payslips
# to a dedicated mailbox and the worker ingests the attachments automatically)
# Disabled until INGEST_IMAP_HOST, INGEST_IMAP_USER, and INGEST_IMAP_PASS are
# all set. Only senders on the allowlist (Settings > Email-in documents) are
# processed; everything else is marked read and skipped.
# INGEST_IMAP_HOST=imap.example.com
# INGEST_IMAP_PORT=993              # defaults: 993 when secure, 143 otherwise
# INGEST_IMAP_SECURE=true           # false to use STARTTLS/cleartext port 143
# INGEST_IMAP_USER=ingest@example.com
# INGEST_IMAP_PASS=app-password
# INGEST_FOLDER=INBOX               # mailbox folder to poll
# INGEST_DEFAULT_BOOK=              # fallback book GUID for senders without one

# MinIO (optional — enable with: --profile storage)
# The root user/password are also used as the default S3 access/secret keys.
# To create access keys separate from root credentials:
#   1. Start MinIO: docker compose -f docker-compose.prod.yml --profile storage up -d minio
#   2. Open the MinIO console at http://<host>:9001 (login with root user/password below)
#   3. Go to Access Keys > Create Access Key — copy the generated key pair
#   4. Set RECEIPT_S3_ACCESS_KEY and RECEIPT_S3_SECRET_KEY to the new key pair
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
